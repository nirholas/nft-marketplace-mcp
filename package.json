{
	"name": "@three-ws/marketplace-mcp",
	"version": "0.1.0",
	"mcpName": "io.github.nirholas/marketplace-mcp",
	"description": "Browse the three.ws agent marketplace and skills catalog from any AI agent. browse_agents and browse_skills search & page the public listings; agent_detail and the category tools round out discovery. Read-only — no key, no signer, no payment.",
	"type": "module",
	"author": "nirholas <support@three.ws>",
	"license": "SEE LICENSE IN LICENSE",
	"homepage": "https://three.ws",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nirholas/marketplace-mcp.git"
	},
	"bugs": {
		"url": "https://github.com/nirholas/three.ws/issues"
	},
	"keywords": [
		"mcp",
		"three.ws",
		"marketplace",
		"agents",
		"skills",
		"discovery"
	],
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"src",
		"server.json",
		"README.md",
		"LICENSE"
	],
	"bin": {
		"marketplace-mcp": "src/index.js"
	},
	"main": "./src/index.js",
	"exports": {
		".": "./src/index.js"
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"start": "node src/index.js",
		"test": "node --test \"test/**/*.test.mjs\"",
		"inspect": "npx -y @modelcontextprotocol/inspector node src/index.js"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^3.23.8"
	}
}
